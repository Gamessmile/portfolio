<%- include('partials/header') %>

<main class="container mt-5 pt-5 mb-5 text-center d-flex flex-column justify-content-center" style="min-height: 60vh;">
    
    <h1 class="display-1 fw-bold" style="color: var(--text-main); font-family: 'JetBrains Mono', monospace; font-size: 8rem;">
        <%= statusCode %>
    </h1>
    
    <h2 class="h3 mb-4" style="color: var(--accent); font-family: 'JetBrains Mono', monospace;">
        > <%= message %>
    </h2>
    
    <p class="lead mb-5" style="color: var(--text-muted); max-width: 600px; margin: 0 auto;">
        <% if (statusCode === 404) { %>
            <%= __('err_404_msg') %>
        <% } else if (statusCode === 403) { %>
            <%= __('err_403_msg') %>
        <% } else { %>
            <%= __('err_500_msg') %>
        <% } %>
    </p>
    
    <div>
        <a href="/" class="btn btn-custom d-inline-flex align-items-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
            </svg>
            <%= __('btn_back_home') %>
        </a>
    </div>

</main>

<%- include('partials/footer') %>